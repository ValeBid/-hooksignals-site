# ─── Paddle Billing ──────────────────────────────────────────────────────────
# NEXT_PUBLIC_PADDLE_ENV controls client-side environment selection.
# Use "sandbox" for local development, "production" for live traffic.
NEXT_PUBLIC_PADDLE_ENV=production

# Client token from Paddle Dashboard → Developer → Authentication.
# Required by the checkout page. Do NOT hardcode — use Vercel env vars.
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=

# Server-side webhook signing secret from Paddle Dashboard → Notifications.
# Required to verify incoming webhooks. Keep this in server-only env vars.
PADDLE_WEBHOOK_SECRET=

# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server-side only, NEVER expose to client.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Clerk Auth ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
# Optional: override model (default: gpt-4o-mini)
OPENAI_MODEL=

# ─── Apify (YouTube Video Analyzer) ──────────────────────────────────────────
APIFY_TOKEN=
APIFY_YOUTUBE_ACTOR_ID=streamers/youtube-scraper

# ─── Google Analytics (optional) ─────────────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=
